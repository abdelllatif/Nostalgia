<mxfile host="app.diagrams.net" agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/133.0.0.0 Safari/537.36" version="26.0.14">
  <diagram name="Page-1" id="Pld1OiU2EQwr_ZqWpfQZ">
    <mxGraphModel dx="2625" dy="1393" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&quot;data&quot;:&quot;\n    class User {\n        -id: int\n        -name: string\n        -email: string\n        -password: string\n        -role: string\n        -status: string\n        -verified: boolean\n        +register()\n        +login()\n        +updateProfile()\n        +resetPassword()\n        +enable2FA()\n    }\n\n    class Product {\n        -id: int\n        -title: string\n        -description: string\n        -history: text\n        -startingPrice: decimal\n        -currentPrice: decimal\n        -status: string\n        -images: array\n        -sellerId: int\n        +create()\n        +update()\n        +delete()\n        +uploadImages()\n        +updatePrice()\n    }\n\n    class Auction {\n        -id: int\n        -productId: int\n        -startTime: datetime\n        -endTime: datetime\n        -currentPrice: decimal\n        -status: string\n        +start()\n        +end()\n        +placeBid()\n        +checkStatus()\n        +notifyParticipants()\n    }\n\n    class Bid {\n        -id: int\n        -auctionId: int\n        -bidderId: int\n        -amount: decimal\n        -timestamp: datetime\n        +create()\n        +validate()\n        +notify()\n    }\n\n    class Article {\n        -id: int\n        -title: string\n        -content: text\n        -authorId: int\n        -status: string\n        +create()\n        +update()\n        +delete()\n        +publish()\n    }\n\n    class Category {\n        -id: int\n        -name: string\n        -description: string\n        +create()\n        +update()\n        +delete()\n    }\n\n    class Tag {\n        -id: int\n        -name: string\n        +create()\n        +update()\n        +delete()\n    }\n\n    class Comment {\n        -id: int\n        -content: text\n        -userId: int\n        -targetId: int\n        -targetType: string\n        +create()\n        +update()\n        +delete()\n        +moderate()\n    }\n\n    User \&quot;1\&quot; -- \&quot;*\&quot; Product : sells\n    User \&quot;1\&quot; -- \&quot;*\&quot; Bid : places\n    User \&quot;1\&quot; -- \&quot;*\&quot; Article : writes\n    Product \&quot;1\&quot; -- \&quot;1\&quot; Auction : has\n    Product \&quot;*\&quot; -- \&quot;*\&quot; Tag : tagged with\n    Product \&quot;*\&quot; -- \&quot;1\&quot; Category : belongs to\n    Auction \&quot;1\&quot; -- \&quot;*\&quot; Bid : contains\n    Article \&quot;*\&quot; -- \&quot;*\&quot; Tag : tagged with\n    Article \&quot;*\&quot; -- \&quot;1\&quot; Category : belongs to\n    Article \&quot;1\&quot; -- \&quot;*\&quot; Comment : has\n    Product \&quot;1\&quot; -- \&quot;*\&quot; Comment : has&quot;,&quot;format&quot;:&quot;svg&quot;}" id="RSKREhiuMOyj3w9L9kJN-1">
          <mxCell style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" parent="1" vertex="1">
            <mxGeometry width="810" height="1088.87" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
    </mxGraphModel>
